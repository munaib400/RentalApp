<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:StarterApp.ViewModels"
             x:DataType="viewmodels:ItemDetailViewModel"
             x:Class="StarterApp.Views.ItemDetailPage"
             Title="{Binding Title}">
    <ScrollView>
        <StackLayout Padding="20" Spacing="15">
            <Label Text="{Binding Item.Title}" FontSize="24" FontAttributes="Bold"/>
            <Label Text="{Binding Item.Category}" FontSize="16" TextColor="Gray"/>
            <Label Text="{Binding Item.Location}" FontSize="16" TextColor="Gray"/>
            <Label Text="{Binding Item.DailyRate, StringFormat='£{0:F2} per day'}" FontSize="20" TextColor="Purple" FontAttributes="Bold"/>
            <Label Text="Description" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0"/>
            <Label Text="{Binding Item.Description}" FontSize="16"/>
            <Label Text="{Binding Item.Owner.FullName, StringFormat='Listed by: {0}'}" FontSize="14" TextColor="Gray" Margin="0,10,0,0"/>
            <Button Text="Request Rental" Command="{Binding RequestRentalCommand}" BackgroundColor="Purple" TextColor="White" Margin="0,20,0,0" IsVisible="{Binding CanRequestRental}"/>
            <Button Text="Edit Item" Command="{Binding EditItemCommand}" BackgroundColor="Blue" TextColor="White" IsVisible="{Binding CanEditItem}"/>
            <Button Text="Delete Item" Command="{Binding DeleteItemCommand}" 
        BackgroundColor="Red" TextColor="White" 
        IsVisible="{Binding CanDeleteItem}"/>
        </StackLayout>
    </ScrollView>
</ContentPage>